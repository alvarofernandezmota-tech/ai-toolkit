{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/groq-fallback",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Colmena",
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "apiKey": "sk-litellm-local",
        "compatibility": "compatible"
      },
      "models": {
        "groq-fallback":         { "name": "Llama 3.3 70B ⚡ DEFAULT — computer-mode, agentes, instrucciones" },
        "principal":             { "name": "Principal (auto-fallback)" },
        "ollama-coder":          { "name": "Qwen2.5 Coder 14B LOCAL 🖥️ — solo generación código puro" },
        "ollama-fast":           { "name": "Qwen3 8B LOCAL ⚡ rápido" },
        "ollama-deepseek":       { "name": "DeepSeek R1 14B LOCAL 🤔 thinking" },
        "sambanova-llama4":      { "name": "SambaNova Llama 4 Maverick" },
        "sambanova-deepseek":    { "name": "SambaNova DeepSeek R1" },
        "sambanova-deepseek-v3": { "name": "SambaNova DeepSeek V3" },
        "together-llama4":       { "name": "Together Llama 4 Maverick" },
        "together-deepseek":     { "name": "Together DeepSeek R1" },
        "llama-4-maverick":      { "name": "Llama 4 Maverick (OpenRouter)" },
        "llama-4-scout":         { "name": "Llama 4 Scout (OpenRouter free)" },
        "qwen3-235b":            { "name": "Qwen3 235B (Cerebras)" },
        "mistral-large":         { "name": "Mistral Large" },
        "codestral":             { "name": "Codestral" },
        "claude-sonnet":         { "name": "Claude Sonnet" },
        "gpt-4o":                { "name": "GPT-4o" },
        "gemini-pro":            { "name": "Gemini 2.5 Pro ⚠️ cuota limitada" },
        "gemini-flash":          { "name": "Gemini 2.0 Flash ⚠️ cuota agotada" },
        "gemini-flash-lite":     { "name": "Gemini 2.0 Flash Lite ⚠️ cuota agotada" }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local (GTX 1060) — solo código puro",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama",
        "compatibility": "compatible"
      },
      "models": {
        "qwen2.5-coder:14b":   { "name": "Qwen2.5 Coder 14B 🖥️ código puro (no computer-mode)" },
        "qwen2.5-coder:7b":    { "name": "Qwen2.5 Coder 7B ⚡ rápido (6GB VRAM)" },
        "qwen3:8b-q4_K_M":     { "name": "Qwen3 8B 🧠 Thinking LOCAL" },
        "deepseek-r1:14b":     { "name": "DeepSeek R1 14B 🤔 Thinking (VRAM+RAM)" },
        "nomic-embed-text":    { "name": "Nomic Embed Text (RAG/Embeddings)" }
      }
    }
  },
  "keybinds": {
    "leader": "ctrl+x"
  }
}
