{
  "$schema": "https://opencode.ai/config.json",
  "model": "litellm/principal",
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM Colmena",
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "apiKey": "sk-litellm-local"
      },
      "models": {
        "principal":             { "name": "Principal (auto-fallback)" },
        "gemini-pro":            { "name": "Gemini 2.5 Pro" },
        "gemini-flash":          { "name": "Gemini 2.0 Flash" },
        "gemini-flash-lite":     { "name": "Gemini 2.0 Flash Lite" },
        "claude-sonnet":         { "name": "Claude Sonnet" },
        "claude-opus":           { "name": "Claude Opus" },
        "gpt-4o":                { "name": "GPT-4o" },
        "gpt-4o-mini":           { "name": "GPT-4o Mini" },
        "o3-mini":               { "name": "o3-mini" },
        "sambanova-llama4":      { "name": "SambaNova Llama 4 Maverick" },
        "sambanova-deepseek":    { "name": "SambaNova DeepSeek R1" },
        "sambanova-deepseek-v3": { "name": "SambaNova DeepSeek V3" },
        "together-llama4":       { "name": "Together Llama 4 Maverick" },
        "together-deepseek":     { "name": "Together DeepSeek R1" },
        "llama-4-maverick":      { "name": "Llama 4 Maverick (OpenRouter)" },
        "llama-4-scout":         { "name": "Llama 4 Scout (OpenRouter free)" },
        "qwen3-235b":            { "name": "Qwen3 235B" },
        "mistral-large":         { "name": "Mistral Large" },
        "codestral":             { "name": "Codestral" },
        "groq-fallback":         { "name": "Groq Fallback" },
        "cerebras-fallback":     { "name": "Cerebras Fallback" },
        "openrouter-fallback":   { "name": "OpenRouter Fallback" },
        "gemini-fallback":       { "name": "Gemini Fallback" }
      }
    },
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama Local (GTX 1060)",
      "options": {
        "baseURL": "http://localhost:11434/v1",
        "apiKey": "ollama"
      },
      "models": {
        "qwen3:8b-q4_K_M":              { "name": "Qwen3 8B 🧠 Thinking LOCAL" },
        "qwen2.5-coder:7b-instruct-q4_K_M": { "name": "Qwen2.5 Coder 7B LOCAL" },
        "deepseek-r1:7b":               { "name": "DeepSeek R1 7B Thinking LOCAL" }
      }
    }
  },
  "keybinds": {
    "leader": "ctrl+x"
  }
}
