# =============================================================================
# .gitignore — ai-toolkit
# =============================================================================

# ─── Keys y secretos (NUNCA a GitHub) ───────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*_key.txt
secrets/

# ─── Python ──────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ─── Node.js ─────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-error.log*
.npm/

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
/tmp/

# ─── LiteLLM ─────────────────────────────────────────────────────────────────
litellm_cache/
.litellm/
proxy_server_config.yaml.bak

# ─── OpenCode / Aider ────────────────────────────────────────────────────────
.aider/
.aider.tags.cache.v3/
.aider.chat.history.md

# ─── Resultados de benchmark (los individuales, no el resumen) ───────────────
investigacion/benchmark-results/*.json
investigacion/benchmark-results/*.tmp

# ─── macOS ───────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─── Editor ──────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Sistema ─────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db

# ─── Archivos temporales de scripts ──────────────────────────────────────────
/tmp/
*.tmp
*.bak
AUDITORIA-*.md
