# =============================================================================
# .env.example — Plantilla de variables de entorno para ai-toolkit
# =============================================================================
# Copia este archivo: cp .env.example .env
# Luego rellena tus keys reales en .env (NUNCA subas .env a GitHub)
#
# O añade las variables directamente a tu ~/.bashrc:
#   echo 'export GROQ_API_KEY="tu_key"' >> ~/.bashrc && source ~/.bashrc
# =============================================================================

# ─── OBLIGATORIAS (al menos una de las gratuitas) ────────────────────────────

# Cerebras — gratis, 128K contexto, muy rápido
# Conseguir: https://cloud.cerebras.ai → API Keys
CEREBRAS_API_KEY=

# OpenRouter — acceso a 200+ modelos, tier gratuito generoso
# Conseguir: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── RECOMENDADAS (gratuitas, amplían la colmena) ────────────────────────────

# Groq — inferencia a 750 tok/s, 14.400 req/día gratis
# Conseguir: https://console.groq.com/keys
# Estado: renovar si da 401
GROQ_API_KEY=

# Google AI Studio — Gemini 2.0 Flash, 1M tokens contexto, 1500 req/día
# Conseguir: https://aistudio.google.com/apikey
# IMPORTANTE: la variable se llama GOOGLE_GENERATIVE_AI_API_KEY, no GOOGLE_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek — DeepSeek R1/V3 muy baratos (no gratis pero casi)
# Conseguir: https://platform.deepseek.com
# Estado: renovar si da 401
DEEPSEEK_API_KEY=

# ─── OPCIONALES (de pago, solo si los necesitas) ─────────────────────────────

# Anthropic — Claude Sonnet/Opus directos (sin OpenRouter)
ANTHROPIC_API_KEY=

# OpenAI — GPT-4o, o3-mini directos
OPENAI_API_KEY=

# Mistral — Mistral Large, Codestral directos
MISTRAL_API_KEY=

# SambaNova — Llama-4-Maverick, DeepSeek-R1 gratis
# Conseguir: https://cloud.sambanova.ai
SAMBANOVA_API_KEY=

# Together AI — modelos open source, $1 crédito gratis
# Conseguir: https://api.together.ai
TOGETHER_API_KEY=

# Tavily — Búsqueda web para THDORA (1000 búsquedas/mes gratis)
# Conseguir: https://tavily.com → Dashboard
# Planificado para Junio 2026 en THDORA
TAVILY_API_KEY=

# ─── TELEGRAM (solo si corres THDORA) ────────────────────────────────────────

# Token del bot — obtener con @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# ─── CONFIGURACIÓN LOCAL (no son keys, no cambiar salvo necesidad) ───────────

# Puerto de LiteLLM proxy
LITELLM_PORT=8000

# Master key del proxy LiteLLM (puedes dejarla como está)
LITELLM_MASTER_KEY=sk-litellm-local

# Puerto de Ollama (por defecto 11434)
OLLAMA_PORT=11434

# =============================================================================
# VERIFICACIÓN RÁPIDA
# Después de rellenar, ejecuta:
#   source .env && bash scripts/health-check.sh
#
# O añade al ~/.bashrc:
#   set -a && source ~/ai-toolkit/.env && set +a
# =============================================================================
